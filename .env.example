# Copy this file to .env before running Docker Compose.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-this-password
DOVIDEO_MINIO_PUBLIC_ENDPOINT=localhost:9000

# SiliconFlow ASR example:
DOVIDEO_ASR_API_URL=https://api.siliconflow.cn/v1/audio/transcriptions
DOVIDEO_ASR_API_KEY=
DOVIDEO_ASR_MODEL=FunAudioLLM/SenseVoiceSmall

# OpenAI-compatible chat-completions endpoint. If omitted, an extractive fallback summary is used.
# DOVIDEO_LLM_BASE_URL=https://api.openai.com/v1
DOVIDEO_LLM_BASE_URL=
DOVIDEO_LLM_API_KEY=
DOVIDEO_LLM_MODEL=deepseek-ai/DeepSeek-V3
